# Copy to terraform.tfvars and fill in sensitive values.
# Do NOT commit terraform.tfvars — it contains secrets.

proxmox_api_token = "root@pam!tokenid=secret"


# Optional overrides (defaults are set in variables.tf):
# proxmox_endpoint = "https://roshar.local.ryk.sh:8006"
# proxmox_node     = "roshar"
# talos_version    = "v1.6.0"
# cluster_name     = "demiurge"

# Network settings (adjust for your network):
# gateway          = "192.168.1.1"
# dns_servers      = ["192.168.1.1"]
# subnet_prefix    = 24

# Control plane settings:
# cp_vm_id         = 101
# cp_hostname      = "demiurge-cp-01"
# cp_ip            = "192.168.1.101"
# cp_cpu           = 2
# cp_memory        = 4096
# cp_disk_size     = 20

